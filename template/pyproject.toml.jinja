[project]
name = "{{ project_slug }}"
version = "0.1.0"
authors = [{ name = "{{ author_name }}", email = "{{ author_email }}" }]
requires-python = ">={{ python_version }}"
dependencies = []

[dependency-groups]
dev = [
	"mypy>=1.0",
	"pytest>=8.0",
	"pytest-cov>=5.0",
	"ruff>=0.9",
]

[build-system]
requires = ["hatchling"]
build-backend = "hatchling.build"

[tool.hatch.build.targets.wheel]
packages = ["src/{{ project_slug }}"]

# Ruff
[tool.ruff]
target-version = "py{{ python_version | replace('.', '') }}"
line-length = 88

[tool.ruff.lint]
select = ["ALL"]
ignore = [
	"ANN003",  # Missing type annotation for **kwargs
	"CPY001",  # Missing copyright notice at top of file (LICENSE file is sufficient)
	"D107",    # Missing docstring in `__init__` (put it on the class instead)
	"D203",    # 1 blank line required before class docstring (conflicts with D211)
	"D206",    # Docstring should be indented with spaces, not tabs (formatter handles this)
	"D212",    # Multi-line docstring summary should start at first line (conflicts with D213)
	"D413",    # Missing blank line after last section
	"E203",    # Whitespace before ':' (conflicts with black slice style `list[1 : 1 + 1]`)
	"ERA001",  # Found commented-out code
	"ISC001",  # Implicitly concatenated string literals (conflicts with ruff formatter)
	"TD003",   # Missing issue link on the line following this TODO
	"W191",    # Indentation contains tabs (formatter handles this)
]
unfixable = [
	"B007",  # Loop control variable not used in loop body
	"B905",  # `zip()` without an explicit `strict=` parameter
	"D204",  # 1 blank line required after class docstring
	"F401",  # Imported but unused
	"F841",  # Local variable is assigned to but never used
]

[tool.ruff.lint.extend-per-file-ignores]
"**/__init__.py" = [
	"D104",  # Missing docstring in public package
]
"test/**/*.py" = [
	"D100",    # Missing docstring in public module
	"D103",    # Missing docstring in public function
	"DOC201",  # `return` is not documented in docstring
	"FBT",     # Boolean positional args (common in @pytest.mark.parametrize)
	"INP001",  # File is part of an implicit namespace package
	"PLR2004", # Magic value used in comparison
	"S101",    # Use of `assert` detected
	"S311",    # Standard pseudo-random generators
]

[tool.ruff.lint.isort]
no-lines-before = ["local-folder"]
split-on-trailing-comma = true
combine-as-imports = true
force-wrap-aliases = true

[tool.ruff.lint.flake8-annotations]
mypy-init-return = true

[tool.ruff.lint.flake8-unused-arguments]
ignore-variadic-names = true

[tool.ruff.lint.flake8-bugbear]
extend-immutable-calls = ["typer.Argument", "typer.Option"]

[tool.ruff.lint.pep8-naming]
classmethod-decorators = ["classmethod"]

[tool.ruff.lint.pydocstyle]
convention = "numpy"

[tool.ruff.format]
quote-style = "double"
docstring-code-format = true
line-ending = "lf"
skip-magic-trailing-comma = false

# Mypy
[tool.mypy]
python_version = "{{ python_version }}"
strict = true
warn_return_any = true
warn_unused_configs = true

# Add per-library overrides here as needed, e.g.:
# [[tool.mypy.overrides]]
# module = "some_untyped_lib.*"
# ignore_missing_imports = true

# Pytest
[tool.pytest.ini_options]
testpaths = ["test"]
pythonpath = ["src"]
addopts = [
	"--cov={{ project_slug }}",
	"--cov-report=term-missing",
	"--cov-report=html",
]
